            upright_frac = ep_upright / ep_steps if ep_steps > 0 else 0.0
            episode_log.append({'step': step + 1, 'episode_return': ep_return, 'upright_fraction': upright_frac})
            obs, _ = env.reset()
            ep_return = 0.0
            ep_steps = 0
            ep_upright = 0
    env.close()
    return actor, critic, episode_log

