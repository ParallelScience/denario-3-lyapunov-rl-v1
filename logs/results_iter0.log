**Code Explanation:**

The provided Python script loads the computed metrics and grid data generated in Step 4 and creates two high-resolution multi-panel figures to visualize the results. 

1. **Learning Curves and Stability Plot**: The `plot_learning_and_stability` function creates a figure with two subplots. The first subplot displays the learning curves (cumulative reward vs. environment steps) for Vanilla SAC, Condition A, and Condition B. It plots the mean across 5 seeds as a solid line and the standard deviation as a shaded region. The second subplot shows the upright stability metric (fraction of time steps where the pendulum is in the upright region, i.e., |theta| < 0.1 rad) evaluated periodically over the training process.

2. **Value Function Heatmaps Plot**: The `plot_value_function_heatmaps` function creates a 2x2 grid of subplots to visualize the value functions and residuals across the state space (angle theta and angular velocity theta_dot). 
   - Subplot (a) shows the analytic Lyapunov function Phi(s).
   - Subplot (b) shows the learned value Q(s, a) for Condition A.
   - Subplot (c) shows the learned value Q(s, a) for Condition B.
   - Subplot (d) shows the learned residual f_theta(s, a) for Condition B.
   Subplots (a), (b), and (c) share a consistent colorbar scale to allow for direct visual comparison. Subplot (d) uses a diverging colormap (`RdBu_r`) centered at zero to clearly highlight positive and negative corrections made by the residual network.

Both plots are saved as PNG files in the `data/` directory with descriptive filenames and timestamps, and their filepaths are printed to the console.

**Python Code:**

```python
import os
import pickle
import time
import numpy as np
import matplotlib.pyplot as plt

def plot_learning_and_stability(metrics, timestamp):
    """
    Generates and saves a multi-panel figure containing learning curves and upright stability over time.
    
    The figure contains two subplots:
    1. Learning curves showing cumulative reward vs. environment steps for Vanilla SAC, Condition A, and Condition B.
       The lines represent the mean across 5 seeds, and the shaded regions represent the standard deviation.
    2. Upright stability metric showing the fraction of time steps the pendulum is in the upright region 
       (|theta| < 0.1 rad) over time for all three conditions.
       
    Args:
        metrics (dict): Dictionary containing computed metrics such as 'step_grid', 'learning_curves', 
                        'eval_steps', and 'eval_stabilities'.
        timestamp (int): Current timestamp used for naming the saved plot file.
    """
    fig1, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6))
    
    step_grid = metrics['step_grid']
    eval_steps = metrics['eval_steps']
    
    colors = {'vanilla': 'gray', 'condition_A': 'blue', 'condition_B': 'orange'}
    labels = {'vanilla': 'Vanilla SAC', 'condition_A': 'Condition A (Direct)', 'condition_B': 'Condition B (Structured)'}
    
    for cond in ['vanilla', 'condition_A', 'condition_B']:
        lc = metrics['learning_curves'][cond]
        mean_lc = np.mean(lc, axis=0)
        std_lc = np.std(lc, axis=0)
        
        ax1.plot(step_grid, mean_lc, label=labels[cond], color=colors[cond])
        ax1.fill_between(step_grid, mean_lc - std_lc, mean_lc + std_lc, color=colors[cond], alpha=0.2)
        
        stab = metrics['eval_stabilities'][cond]
        mean_stab = np.mean(stab, axis=0)
        std_stab = np.std(stab, axis=0)
        
        ax2.plot(eval_steps, mean_stab, label=labels[cond], color=colors[cond], marker='o')
        ax2.fill_between(eval_steps, mean_stab - std_stab, mean_stab + std_stab, color=colors[cond], alpha=0.2)
        
    ax1.set_title('Learning Curves')
    ax1.set_xlabel('Environment Steps')
    ax1.set_ylabel('Cumulative Reward')
    ax1.legend()
    ax1.grid(True)
    
    ax2.set_title('Upright Stability Over Time')
    ax2.set_xlabel('Environment Steps')
    ax2.set_ylabel('Fraction of Time Upright (|theta| < 0.1 rad)')
    ax2.legend()
    ax2.grid(True)
    
    fig1.tight_layout()
    fig1_path = os.path.join('data', 'learning_and_stability_1_' + str(timestamp) + '.png')
    fig1.savefig(fig1_path, dpi=300)
    print('Plot saved to ' + fig1_path)
    plt.close(fig1)

def plot_value_function_heatmaps(grid_data, timestamp):
    """
    Generates and saves a figure with subplots for 2D heatmaps of the value functions and residuals.
    
    The figure contains four subplots:
    (a) Analytic Lyapunov function Phi(s).
    (b) Condition A learned value Q(s, a).
    (c) Condition B learned value Q(s, a).
    (d) Condition B learned residual f_theta(s, a).
    
    Subplots (a), (b), and (c) share a consistent colorbar scale.
    Subplot (d) uses a diverging colormap centered at zero.
    
    Args:
        grid_data (dict-like): Dictionary or npz file object containing 'theta', 'theta_dot', 'phi', 
                               'q_A', 'q_B', and 'residual_B' arrays.
        timestamp (int): Current timestamp used for naming the saved plot file.
    """
    fig2, axes = plt.subplots(2, 2, figsize=(14, 12))
    
    theta = grid_data['theta']
    theta_dot = grid_data['theta_dot']
    phi = grid_data['phi']
    q_A = grid_data['q_A']
    q_B = grid_data['q_B']
    residual_B = grid_data['residual_B']
    
    vmin = min(np.min(phi), np.min(q_A), np.min(q_B))
    vmax = max(np.max(phi), np.max(q_A), np.max(q_B))
    
    im0 = axes[0, 0].pcolormesh(theta, theta_dot, phi, shading='auto', cmap='viridis', vmin=vmin, vmax=vmax)
    axes[0, 0].set_title('(a) Analytic Lyapunov Function Phi(s)')
    axes[0, 0].set_xlabel('Angle theta (rad)')
    axes[0, 0].set_ylabel('Angular Velocity theta_dot (rad/s)')
    fig2.colorbar(im0, ax=axes[0, 0])
    
    im1 = axes[0, 1].pcolormesh(theta, theta_dot, q_A, shading='auto', cmap='viridis', vmin=vmin, vmax=vmax)
    axes[0, 1].set_title('(b) Condition A Learned Value Q(s, a)')
    axes[0, 1].set_xlabel('Angle theta (rad)')
    axes[0, 1].set_ylabel('Angular Velocity theta_dot (rad/s)')
    fig2.colorbar(im1, ax=axes[0, 1])
    
    im2 = axes[1, 0].pcolormesh(theta, theta_dot, q_B, shading='auto', cmap='viridis', vmin=vmin, vmax=vmax)
    axes[1, 0].set_title('(c) Condition B Learned Value Q(s, a)')
    axes[1, 0].set_xlabel('Angle theta (rad)')
    axes[1, 0].set_ylabel('Angular Velocity theta_dot (rad/s)')
    fig2.colorbar(im2, ax=axes[1, 0])
    
    res_max = np.max(np.abs(residual_B))
    im3 = axes[1, 1].pcolormesh(theta, theta_dot, residual_B, shading='auto', cmap='RdBu_r', vmin=-res_max, vmax=res_max)
    axes[1, 1].set_title('(d) Condition B Learned Residual f_theta(s, a)')
    axes[1, 1].set_xlabel('Angle theta (rad)')
    axes[1, 1].set_ylabel('Angular Velocity theta_dot (rad/s)')
    fig2.colorbar(im3, ax=axes[1, 1])
    
    fig2.tight_layout()
    fig2_path = os.path.join('data', 'value_function_heatmaps_2_' + str(timestamp) + '.png')
    fig2.savefig(fig2_path, dpi=300)
    print('Plot saved to ' + fig2_path)
    plt.close(fig2)

def main():
    """
    Main execution function. Loads computed metrics and grid data, then calls plotting functions.
    """
    with open(os.path.join('data', 'computed_metrics.pkl'), 'rb') as f:
        metrics = pickle.load(f)
    
    grid_data = np.load(os.path.join('data', 'grid_data.npz'))
    
    timestamp = int(time.time())
    
    plot_learning_and_stability(metrics, timestamp)
    plot_value_function_heatmaps(grid_data, timestamp)

if __name__ == '__main__':
    main()
```

